        foreach ($users as $user) {
            $jobOffers = JobOffer::inRandomOrder()->take(rand(1, 5))->get();

            foreach ($jobOffers as $jobOffer) {
                \App\Models\JobApplication::factory()->create([
                    'user_id' => $user->id,
